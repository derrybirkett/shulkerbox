#!/bin/bash
# post-commit hook — appends an entry to the activity log
# Looks for notes/ directory in the git repo root

# Find the git repo root
REPO_ROOT="$(git rev-parse --show-toplevel)"
LOG_FILE="$REPO_ROOT/notes/activity-log.md"

# Skip if notes directory doesn't exist
if [ ! -d "$REPO_ROOT/notes" ]; then
  exit 0
fi

DATE=$(date +"%Y-%m-%d %H:%M")
REPO=$(basename "$(git rev-parse --show-toplevel)")
BRANCH=$(git branch --show-current)
MSG=$(git log -1 --format="%s")

mkdir -p "$(dirname "$LOG_FILE")"

# Initialise file with header if it doesn't exist
if [ ! -f "$LOG_FILE" ]; then
  echo "# Activity Log" > "$LOG_FILE"
  echo "" >> "$LOG_FILE"
  echo "Auto-populated by post-commit hook. Enriched manually or via the activity-log skill." >> "$LOG_FILE"
  echo "" >> "$LOG_FILE"
fi

{
  echo ""
  echo "## $DATE | $REPO ($BRANCH)"
  echo "**$MSG**"
} >> "$LOG_FILE"
