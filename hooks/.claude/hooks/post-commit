#!/bin/bash
# post-commit hook — appends an entry to the activity log
# Installed globally via: git config --global core.hooksPath ~/.git-hooks

# Find the git repo root
REPO_ROOT="$(git rev-parse --show-toplevel)"

# Check for project-scoped notes, fall back to global
if [ -d "$REPO_ROOT/notes" ]; then
  LOG_FILE="$REPO_ROOT/notes/activity-log.md"
elif [ -d "$HOME/Projects/skills/notes" ]; then
  LOG_FILE="$HOME/Projects/skills/notes/activity-log.md"
else
  # No notes directory found, skip logging
  exit 0
fi

DATE=$(date +"%Y-%m-%d %H:%M")
REPO=$(basename "$(git rev-parse --show-toplevel)")
BRANCH=$(git branch --show-current)
MSG=$(git log -1 --format="%s")

mkdir -p "$(dirname "$LOG_FILE")"

# Initialise file with header if it doesn't exist
if [ ! -f "$LOG_FILE" ]; then
  echo "# Activity Log" > "$LOG_FILE"
  echo "" >> "$LOG_FILE"
  echo "Auto-populated by post-commit hook. Enriched manually or via the activity-log skill." >> "$LOG_FILE"
  echo "" >> "$LOG_FILE"
fi

{
  echo ""
  echo "## $DATE | $REPO ($BRANCH)"
  echo "**$MSG**"
} >> "$LOG_FILE"
