#!/bin/bash
# Session start hook: Show pending work from inbox
# This runs at the beginning of every Claude Code session

INBOX="notes/inbox.md"

# Check if inbox exists
if [ ! -f "$INBOX" ]; then
  exit 0
fi

# Check for handover sections
if ! grep -q "## Handover —" "$INBOX" 2>/dev/null; then
  exit 0
fi

echo ""
echo "📥 Session Pickup Available"
echo "   Run /pickup to see where you left off"

# Count urgent items
urgent=$(grep -c "@urgent" "$INBOX" 2>/dev/null || echo 0)
if [ "$urgent" -gt 0 ]; then
  echo "   ⚠️  $urgent urgent item(s) waiting"
fi

# Count in-progress items
in_progress=$(grep -c "@in-progress" "$INBOX" 2>/dev/null || echo 0)
if [ "$in_progress" -gt 0 ]; then
  echo "   🟡 $in_progress item(s) in progress"
fi

# Count blocked items
blocked=$(grep -c "@blocked\|@waiting-on" "$INBOX" 2>/dev/null || echo 0)
if [ "$blocked" -gt 0 ]; then
  echo "   🔵 $blocked item(s) blocked/waiting"
fi

echo ""

exit 0
